              "raw": "{{base_url}}/api/v1/datacenter/customers/analysis?start_date=2025-01-01&end_date=2025-12-31",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "customers", "analysis"],
              "query": [
                {"key": "start_date", "value": "2025-01-01"},
                {"key": "end_date", "value": "2025-12-31"}
              ]
            }
          }
        },
        {
          "name": "获取客户价值分布",
