{
  "info": {
    "name": "OURERP 数据中心 API",
    "description": "数据中心模块API测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "your-jwt-token-here",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "实时监控",
      "item": [
        {
          "name": "获取实时概览",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/datacenter/realtime/overview",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "realtime", "overview"]
            }
          }
        },
        {
          "name": "获取实时库存状态",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/datacenter/realtime/inventory",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "realtime", "inventory"]
            }
          }
        },
        {
          "name": "获取小时趋势",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/datacenter/realtime/hourly-trend",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "realtime", "hourly-trend"]
            }
          }
        }
      ]
    },
    {
