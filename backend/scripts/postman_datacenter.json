              "path": ["api", "v1", "datacenter", "alerts", "records"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "page_size", "value": "20"}
              ]
            }
          }
        },
        {
          "name": "处理预警记录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"已处理，补货中\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/datacenter/alerts/records/1/handle",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "alerts", "records", "1", "handle"]
            }
          }
        },
