              "raw": "{{base_url}}/api/v1/datacenter/customers/city?province=广东&start_date=2025-01-01&end_date=2025-12-31",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "customers", "city"],
              "query": [
                {"key": "province", "value": "广东"},
