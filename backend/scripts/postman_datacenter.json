    {
      "name": "预警管理",
      "item": [
        {
          "name": "获取预警类型",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/datacenter/alerts/types",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "alerts", "types"]
            }
          }
        },
        {
          "name": "获取预警级别",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/datacenter/alerts/levels",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "alerts", "levels"]
            }
          }
        },
        {
          "name": "获取预警汇总",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
