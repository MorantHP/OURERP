          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/datacenter/alerts/rules?page=1&page_size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "alerts", "rules"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "page_size", "value": "20"}
              ]
            }
          }
        },
        {
          "name": "创建预警规则",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"库存预警规则\",\n  \"type\": \"inventory\",\n  \"threshold\": 10,\n  \"level\": \"warning\",\n  \"notify_type\": \"system\",\n  \"description\": \"当库存低于10时触发预警\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/datacenter/alerts/rules",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "datacenter", "alerts", "rules"]
            }
          }
        },
        {
          "name": "获取预警记录列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
