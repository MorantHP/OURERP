# OURERP 后端环境变量配置示例
# 复制此文件为 .env 并修改配置值

# 运行环境: development, production
ENV=development

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=ourerp
DB_PASSWORD=your_secure_password_here
DB_NAME=ourerp
DB_SSLMODE=disable

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
# 生产环境请使用强密钥，至少32位随机字符串
JWT_SECRET=your_jwt_secret_key_at_least_32_chars_long
JWT_EXPIRE=24

# CORS配置
# 允许的域名，多个用逗号分隔
# 开发环境示例: http://localhost:5173,http://127.0.0.1:5173
# 生产环境示例: https://example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
