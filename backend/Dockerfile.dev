# backend/Dockerfile.dev
FROM golang:1.21-alpine

WORKDIR /app

# 安装git和air（热重载工具）
RUN apk add --no-cache git && \
    go install github.com/cosmtrek/air@latest

# 复制依赖文件
COPY go.mod go.sum ./
RUN go mod download

# 复制源代码
COPY . .

# 暴露端口
EXPOSE 8080

# 默认命令（会被docker-compose覆盖）
CMD ["air", "-c", ".air.toml"]